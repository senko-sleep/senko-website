DATABASE_URL=postgresql://senko:senko@localhost:5432/senko

# Bull crawl queue + ioredis: use a Redis protocol URL (e.g. `rediss://default:...@...upstash.io:6379` from Upstash **Redis**).
# QStash (HTTP) is NOT a substitute for this — see QSTASH_* below.
REDIS_URL=redis://localhost:6379

# Optional: Upstash Redis over REST (cache/trending/suggest when you prefer REST over TCP).
# From Upstash Redis dashboard → REST API → URL + token.
UPSTASH_REDIS_REST_URL=
UPSTASH_REDIS_REST_TOKEN=

# QStash (HTTP message queue) — optional; used for serverless-style webhooks, not as Bull’s Redis connection.
# Signing keys verify incoming QStash requests if you add HTTP workers later.
QSTASH_URL=
QSTASH_TOKEN=
QSTASH_CURRENT_SIGNING_KEY=
QSTASH_NEXT_SIGNING_KEY=

CRAWLER_MAX_WORKERS=5
CRAWL_DELAY_MS=1000
MAX_PAGES_PER_JOB=2000
CRAWLER_USER_AGENT=SenkoBot/1.0
QUEUE_NAME=senko:crawl

# Crawl entry points (live web — whatever you add here is fetched over HTTP, then the spider follows links).
# Required for `npm run crawl:enqueue` unless every job sends `seedUrls` in POST /api/crawl. Nothing is baked into the codebase.
# Example (uncomment and edit):
# SENKO_SEED_URLS=https://www.wikipedia.org/wiki/Main_Page,https://community.fandom.com/wiki/Community_Central
SENKO_SEED_URLS=

# Defaults for `npm run crawl:enqueue` (depth/pages/seeds cap)
# CRAWL_CLI_MAX_DEPTH=2
# CRAWL_CLI_MAX_PAGES=250
# CRAWL_CLI_MAX_SEEDS=40

API_PORT=4000
CORS_ORIGIN=http://localhost:3000
RATE_LIMIT_WINDOW_MS=60000
RATE_LIMIT_MAX=60

PAGERANK_CRON=0 3 * * *
PAGERANK_ITERATIONS=20

NEXT_PUBLIC_API_URL=http://localhost:4000

# Open-web search: default `meta` = DuckDuckGo + Bing + Google (lite) + Brave HTML in parallel — **no API keys**.
# WEB_SEARCH_PROVIDER=meta
# `local` = only your crawl. `brave` = official Brave JSON API. `hybrid` = meta web + your crawl.
# BRAVE_SEARCH_API_KEY=
